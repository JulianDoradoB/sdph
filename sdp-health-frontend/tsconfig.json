{
  "compilerOptions": {
    /* Entorno de Destino y Librerías */
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* 🚀 Configuración Crucial para React */
    "jsx": "react-jsx",

    /* Estrategia de Resolución de Módulos */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Reglas de Tipado Estricto */
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    
    /* Diagnósticos y Limpieza de Código */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.css",        /* ⬅️ Línea nueva 1: Le dice a TS que reconozca tus estilos */
    "src/vite-env.d.ts",   /* ⬅️ Línea nueva 2: Enlaza los tipos globales de Vite */
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}